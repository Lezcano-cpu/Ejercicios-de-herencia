class Animal:
    def __init__(self, nombre, especie, edad):
        self.nombre = nombre
        self.especie = especie
        self.edad = edad
    
    def mostrar_detalles_generales(self):
        print(f"Animal: {self.nombre}")
        print(f"Especie: {self.especie}")
        print(f"Edad: {self.edad} años")

class Perro(Animal):
    def __init__(self, nombre, edad, raza):
        super().__init__(nombre, "Perro", edad)
        self.raza = raza
    
    def emitir_sonido(self):
        return "¡Guau, guau!"
    
    def mostrar_detalles(self):
        self.mostrar_detalles_generales()
        print(f"Raza: {self.raza}")
        print(f"Sonido: {self.emitir_sonido()}")

class Gato(Animal):
    def __init__(self, nombre, edad, color_pelaje):
        super().__init__(nombre, "Gato", edad)
        self.color_pelaje = color_pelaje
    
    def emitir_sonido(self):
        return "¡Miau, miau!"
    
    def mostrar_detalles(self):
        self.mostrar_detalles_generales()
        print(f"Color de Pelaje: {self.color_pelaje}")
        print(f"Sonido: {self.emitir_sonido()}")
